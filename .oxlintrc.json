{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-floating-promises": "off"
  },
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "react", "import", "jsx-a11y", "vitest"],
  "ignorePatterns": [
    "changelog.config.js",
    "*.d.ts",
    "**/components/ui/**/*",
    "**/src/gql/**/*",
    "web/packages/portal/src/hooks/use-mobile.ts"
  ],
  "overrides": [
    {
      "files": ["**/*.config.{js,ts}", "**/codegen.ts"],
      "env": {
        "node": true
      }
    },
    {
      "files": ["**/*.test.{ts,tsx}", "web/config/test/**/*.ts"],
      "env": {
        "vitest": true
      }
    }
  ],
  "options": {
    "typeAware": true,
    "reportUnusedDisableDirectives": "error"
  }
}
