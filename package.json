    "oxlint": "oxlint --ignore-path ./.eslintignore --tsconfig=./tsconfig.json -c ./.oxlintrc.json --type-aware",
    "knip": "knip --config knip.json",
    "tslint": "tsc --build ./tsconfig.json",
    "test": "vitest run",
    "build": "pnpm --filter './web/packages/*' run build",
    "commit": "git-cz",
    "prepare": "husky"
  },
